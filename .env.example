NODE_ENV=production
HOST=0.0.0.0
PORT=3000
APP_BASE_URL=http://localhost:3000

# Upstream JunimoServer API endpoint, e.g. http://127.0.0.1:8080
JUNIMO_BASE_URL=http://127.0.0.1:8080

# Upstream JunimoServer API key. The browser never sees this value.
JUNIMO_API_KEY=replace-with-upstream-api-key

# WebUI login secret. Require at least 12 chars.
ADMIN_PASSWORD=replace-with-long-admin-password

# Optional. If omitted, the server derives a stable secret from ADMIN_PASSWORD.
SESSION_SECRET=replace-with-32-char-random-secret

# Session TTL for the WebUI login cookie.
SESSION_TTL_HOURS=12

# Set to true when running behind a trusted reverse proxy.
TRUST_PROXY=false

# Login and action rate limits.
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=6
ACTION_RATE_LIMIT_WINDOW_MS=60000
ACTION_RATE_LIMIT_MAX_ATTEMPTS=30
